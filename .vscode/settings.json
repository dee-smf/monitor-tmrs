{
    // Resolve o erro do PATH apontando diretamente para o executável do seu .venv
    "mypy.dmypyExecutable": "${workspaceFolder}/.venv/bin/dmypy",

    // Mantém a extensão integrada ao interpretador do projeto
    "mypy.runUsingActiveInterpreter": true,

    // Executa a checagem em todo o projeto (estilo Pyright)
    "mypy.targets": ["."],
    
    // "mypy.extraArguments": [
    //     "--ignore-missing-imports"
    // ]
}

